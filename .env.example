# Copy to .env.local for local development

APP_ENV=dev
APP_SECRET=change-me

# Symfony routing
DEFAULT_URI=http://localhost

# Doctrine / DB
# For Railway, Railway will override DATABASE_URL at runtime.
# Keep this local default for convenience.
DATABASE_URL="mysql://app:apppassword@127.0.0.1:3307/app?serverVersion=8.0&charset=utf8mb4"

# Messenger (Doctrine transport)
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# Mailer (Brevo/SMTP)
MAILER_DSN=smtp://YOUR_LOGIN:YOUR_SMTP_KEY@smtp-relay.brevo.com:587

# App payment
PAYMENT_SIMULATE=1

# Google OAuth
GOOGLE_OAUTH_REDIRECT_BASE_URI=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

