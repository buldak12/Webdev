{% extends 'admin/base.html.twig' %}

{% block title %}{% if product %}Edit Product{% else %}New Product{% endif %}{% endblock %}
{% block breadcrumb %}Catalog / Products / {% if product %}Edit{% else %}New{% endif %}{% endblock %}

{% block body %}
<div class="page-header d-flex justify-content-between align-items-center">
    <h1>{% if product %}Edit Product{% else %}Add New Product{% endif %}</h1>
    <a href="{{ path('admin_products') }}" class="btn btn-outline-secondary btn-icon" title="Back to products" aria-label="Back to products">
        <i class="bi bi-arrow-left" aria-hidden="true"></i>
        <span class="visually-hidden">Back to Products</span>
    </a>
</div>

<form method="post">
    <div class="row">
        <!-- Main Content -->
        <div class="col-lg-8">
            <!-- Basic Info -->
            <div class="card mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Basic Information</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Product Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="name" value="{{ product ? product.name : '' }}" placeholder="e.g., Lilac Ice Premium E-Liquid" required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">SKU <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="sku" value="{{ product ? product.sku : '' }}" placeholder="e.g., LIL-ICE-30" {{ product ? 'readonly' : '' }} required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Category <span class="text-danger">*</span></label>
                            <select class="form-select" name="category_id" required>
                                <option value="">Select category...</option>
                                {% for category in categories %}
                                    <option value="{{ category.id }}" {{ product and product.category and product.category.id == category.id ? 'selected' : '' }}>{{ category.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Short Description</label>
                        <input type="text" class="form-control" name="short_description" value="{{ product ? product.shortDescription : '' }}" placeholder="e.g., 30ml bottle">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" name="description" rows="4" placeholder="Enter product description...">{{ product ? product.description : '' }}</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Brand</label>
                        <input type="text" class="form-control" name="brand" value="{{ product ? product.brand : '' }}" placeholder="e.g., VapeShop Premium">
                    </div>
                </div>
            </div>

            <!-- Variants -->
            <div class="card mb-4">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Product Variants</h5>
                    <button type="button" class="btn btn-sm btn-outline-primary btn-icon" onclick="addVariantRow()" title="Add variant" aria-label="Add variant">
                        <i class="bi bi-plus-lg" aria-hidden="true"></i>
                        <span class="visually-hidden">Add Variant</span>
                    </button>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">Add variants for different nicotine strengths or flavors.</p>
                    
                    <!-- Variant Table -->
                    <div class="table-responsive">
                        <table class="table table-bordered" id="variantsTable">
                            <thead class="table-light">
                                <tr>
                                    <th>Flavor</th>
                                    <th>Nicotine</th>
                                    <th style="width: 120px;">Price Mod (₱)</th>
                                    <th style="width: 100px;">Stock</th>
                                    <th style="width: 60px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% if product and product.variants|length > 0 %}
                                    {% for variant in product.variants %}
                                    <tr>
                                        <td><input type="text" class="form-control form-control-sm" name="variant_flavor[]" value="{{ variant.flavor }}"></td>
                                        <td><input type="text" class="form-control form-control-sm" name="variant_nicotine[]" value="{{ variant.nicotineStrength }}"></td>
                                        <td><input type="number" step="0.01" class="form-control form-control-sm" name="variant_price[]" value="{{ variant.priceModifier }}"></td>
                                        <td><input type="number" class="form-control form-control-sm" name="variant_stock[]" value="{{ variant.stock }}"></td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-outline-danger btn-icon" onclick="this.closest('tr').remove()" title="Remove variant" aria-label="Remove variant">
                                                <i class="bi bi-trash" aria-hidden="true"></i>
                                                <span class="visually-hidden">Remove</span>
                                            </button>
                                        </td>
                                    </tr>
                                    {% endfor %}
                                {% else %}
                                <tr>
                                    <td><input type="text" class="form-control form-control-sm" name="variant_flavor[]" placeholder="e.g., Mint"></td>
                                    <td><input type="text" class="form-control form-control-sm" name="variant_nicotine[]" placeholder="e.g., 3mg"></td>
                                    <td><input type="number" step="0.01" class="form-control form-control-sm" name="variant_price[]" value="0"></td>
                                    <td><input type="number" class="form-control form-control-sm" name="variant_stock[]" value="0"></td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-danger btn-icon" onclick="this.closest('tr').remove()" title="Remove variant" aria-label="Remove variant">
                                            <i class="bi bi-trash" aria-hidden="true"></i>
                                            <span class="visually-hidden">Remove</span>
                                        </button>
                                    </td>
                                </tr>
                                {% endif %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Images -->
            <div class="card mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Product Images</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Image URL</label>
                        <input type="text" class="form-control" name="main_image" value="{{ product ? product.mainImage : 'images/lilac-prod-300x300.png' }}" placeholder="images/product.png">
                    </div>
                    {% if product and product.mainImage %}
                    <img src="{{ asset(product.mainImage) }}" class="img-thumbnail" style="max-height: 150px;">
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Publish -->
            <div class="card mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Publish</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="is_active" id="isActive" {{ (not product) or product.isActive ? 'checked' : '' }}>
                            <label class="form-check-label" for="isActive">Active</label>
                        </div>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-icon" title="{{ product ? 'Update product' : 'Save product' }}" aria-label="{{ product ? 'Update product' : 'Save product' }}">
                            <i class="bi bi-check-lg" aria-hidden="true"></i>
                            <span class="visually-hidden">{{ product ? 'Update Product' : 'Save Product' }}</span>
                        </button>
                        <a href="{{ path('admin_products') }}" class="btn btn-outline-secondary btn-icon" title="Cancel" aria-label="Cancel">
                            <i class="bi bi-x-lg" aria-hidden="true"></i>
                            <span class="visually-hidden">Cancel</span>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Pricing -->
            <div class="card mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Pricing</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Base Price (₱) <span class="text-danger">*</span></label>
                        <input type="number" step="0.01" class="form-control" name="base_price" value="{{ product ? product.basePrice : '' }}" placeholder="0.00" required>
                    </div>
                </div>
            </div>

            <!-- Age Restriction -->
            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Age Restriction</h5>
                </div>
                <div class="card-body">
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" name="requires_age_verification" id="ageRestricted" {{ (not product) or product.requiresAgeVerification ? 'checked' : '' }}>
                        <label class="form-check-label" for="ageRestricted">
                            Requires age verification (18+)
                        </label>
                    </div>
                    <small class="text-muted">This product contains nicotine and requires age verification before purchase.</small>
                </div>
            </div>
        </div>
    </div>
</form>

<script>
function addVariantRow() {
    const tbody = document.querySelector('#variantsTable tbody');
    const row = document.createElement('tr');
    row.innerHTML = `
        <td><input type="text" class="form-control form-control-sm" name="variant_flavor[]" placeholder="e.g., Mint"></td>
        <td><input type="text" class="form-control form-control-sm" name="variant_nicotine[]" placeholder="e.g., 3mg"></td>
        <td><input type="number" step="0.01" class="form-control form-control-sm" name="variant_price[]" value="0"></td>
        <td><input type="number" class="form-control form-control-sm" name="variant_stock[]" value="0"></td>
        <td>
            <button type="button" class="btn btn-sm btn-outline-danger btn-icon" onclick="this.closest('tr').remove()" title="Remove variant" aria-label="Remove variant">
                <i class="bi bi-trash" aria-hidden="true"></i>
                <span class="visually-hidden">Remove</span>
            </button>
        </td>
    `;
    tbody.appendChild(row);
}
</script>
{% endblock %}
