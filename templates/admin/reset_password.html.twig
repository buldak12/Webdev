{% extends 'base.html.twig' %}

{% block title %}Reset Admin Password{% endblock %}

{% block body %}
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <h2>Reset Admin Password</h2>

      {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
      {% endfor %}
      {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
      {% endfor %}

      <form method="post">
        <div class="mb-3">
          <label for="token" class="form-label">Reset Token</label>
          <input id="token" name="token" class="form-control" value="{{ tokenPrefill }}" required>
        </div>
        <div class="mb-3">
          <label for="password" class="form-label">New Password</label>
          <input id="password" name="password" type="password" class="form-control" required minlength="8">
        </div>
        <button class="btn btn-primary">Reset Password</button>
      </form>
    </div>
  </div>
</div>
{% endblock %}
