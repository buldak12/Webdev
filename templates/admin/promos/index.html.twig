{% extends app.request.get('_route') starts with 'staff_' ? 'staff/base.html.twig' : 'admin/base.html.twig' %}

{% block title %}Promo Codes{% endblock %}
{% block breadcrumb %}Sales / Promo Codes{% endblock %}

{% block body %}
{% set route_prefix = promos_route_prefix|default('admin_promos') %}
{% set activeCount = 0 %}
{% set expiredCount = 0 %}
{% set totalUses = 0 %}
{% set nowTs = date()|date('U') %}

{% for promo in promos %}
    {% set totalUses = totalUses + promo.usageCount %}
    {% if promo.isActive and promo.valid %}
        {% set activeCount = activeCount + 1 %}
    {% endif %}
    {% if promo.expiresAt and promo.expiresAt|date('U') < nowTs %}
        {% set expiredCount = expiredCount + 1 %}
    {% endif %}
{% endfor %}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1>Promo Codes Management</h1>
    <a href="{{ path(route_prefix ~ '_new') }}" class="btn btn-primary btn-icon" title="Create promo code" aria-label="Create promo code">
        <i class="bi bi-plus-lg" aria-hidden="true"></i>
        <span class="visually-hidden">Create Promo Code</span>
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-center py-3">
            <div class="h4 mb-0">{{ promos|length }}</div>
            <small class="text-muted">Loaded Codes</small>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center py-3">
            <div class="h4 mb-0 text-success">{{ activeCount }}</div>
            <small class="text-muted">Currently Active</small>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center py-3">
            <div class="h4 mb-0 text-info">{{ totalUses }}</div>
            <small class="text-muted">Total Uses</small>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center py-3">
            <div class="h4 mb-0 text-warning">{{ expiredCount }}</div>
            <small class="text-muted">Expired</small>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-center">
            <div class="col-md-3">
                <label class="form-label mb-1">Status Filter</label>
                <select class="form-select" name="filter" onchange="this.form.submit()">
                    <option value="" {{ current_filter is empty ? 'selected' : '' }}>All</option>
                    <option value="active" {{ current_filter == 'active' ? 'selected' : '' }}>Active</option>
                    <option value="expired" {{ current_filter == 'expired' ? 'selected' : '' }}>Expired</option>
                </select>
            </div>
            <div class="col-md-9 d-flex align-items-end">
                <small class="text-muted">Showing {{ promos|length }} promo code(s).</small>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Code</th>
                        <th>Description</th>
                        <th>Discount</th>
                        <th>Min. Order</th>
                        <th>Usage</th>
                        <th>Valid Period</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for promo in promos %}
                        {% set usagePct = (promo.usageLimit and promo.usageLimit > 0) ? ((promo.usageCount / promo.usageLimit) * 100) : 0 %}
                        {% set isExpired = promo.expiresAt and promo.expiresAt|date('U') < nowTs %}
                        {% set isExhausted = promo.usageLimit and promo.usageCount >= promo.usageLimit %}

                        <tr class="{{ (not promo.isActive or isExpired) ? 'table-light' : '' }}">
                            <td><code class="fs-6">{{ promo.code }}</code></td>
                            <td>{{ promo.description ?: 'No description' }}</td>
                            <td>
                                {% if promo.type == 'percentage' %}
                                    <span class="badge bg-primary">{{ promo.value|number_format(2) }}% OFF</span>
                                {% elseif promo.type == 'fixed' %}
                                    <span class="badge bg-warning text-dark">₱{{ promo.value|number_format(2) }} OFF</span>
                                {% else %}
                                    <span class="badge bg-info">FREE SHIPPING</span>
                                {% endif %}
                            </td>
                            <td>{{ promo.minimumOrderAmount ? '₱' ~ promo.minimumOrderAmount|number_format(2) : 'None' }}</td>
                            <td>
                                <div>{{ promo.usageCount }} / {{ promo.usageLimit ?: '∞' }}</div>
                                {% if promo.usageLimit %}
                                    <div class="progress" style="height: 4px; width: 90px;">
                                        <div class="progress-bar" style="width: {{ min(100, usagePct)|round(1) }}%"></div>
                                    </div>
                                {% else %}
                                    <small class="text-muted">Unlimited</small>
                                {% endif %}
                            </td>
                            <td>
                                <small>
                                    {{ promo.startsAt ? promo.startsAt|date('M j, Y') : 'Any time' }}
                                    -
                                    {{ promo.expiresAt ? promo.expiresAt|date('M j, Y') : 'No expiry' }}
                                </small>
                            </td>
                            <td>
                                {% if not promo.isActive %}
                                    <span class="badge bg-secondary">Disabled</span>
                                {% elseif isExpired %}
                                    <span class="badge bg-secondary">Expired</span>
                                {% elseif isExhausted %}
                                    <span class="badge bg-warning text-dark">Exhausted</span>
                                {% elseif promo.valid %}
                                    <span class="badge bg-success">Active</span>
                                {% else %}
                                    <span class="badge bg-info">Scheduled</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="d-flex flex-wrap gap-1">
                                    <a href="{{ path(route_prefix ~ '_edit', {id: promo.id}) }}" class="btn btn-sm btn-outline-primary btn-icon" title="Edit promo" aria-label="Edit promo">
                                        <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                        <span class="visually-hidden">Edit</span>
                                    </a>
                                    <form method="post" action="{{ path(route_prefix ~ '_toggle', {id: promo.id}) }}">
                                        <button type="submit" class="btn btn-sm btn-outline-{{ promo.isActive ? 'warning' : 'success' }} btn-icon" title="{{ promo.isActive ? 'Disable promo' : 'Enable promo' }}" aria-label="{{ promo.isActive ? 'Disable promo' : 'Enable promo' }}">
                                            <i class="bi {{ promo.isActive ? 'bi-toggle-off' : 'bi-toggle-on' }}" aria-hidden="true"></i>
                                            <span class="visually-hidden">{{ promo.isActive ? 'Disable' : 'Enable' }}</span>
                                        </button>
                                    </form>
                                    <form method="post" action="{{ path(route_prefix ~ '_delete', {id: promo.id}) }}" onsubmit="return confirm('Delete promo code {{ promo.code }}?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger btn-icon" title="Delete promo" aria-label="Delete promo">
                                            <i class="bi bi-trash" aria-hidden="true"></i>
                                            <span class="visually-hidden">Delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">No promo codes found.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white d-flex justify-content-between align-items-center">
        <div class="text-muted">Showing {{ promos|length }} promo code(s)</div>
    </div>
</div>
{% endblock %}
