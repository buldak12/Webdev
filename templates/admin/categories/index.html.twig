{% extends app.request.get('_route') starts with 'staff_' ? 'staff/base.html.twig' : 'admin/base.html.twig' %}

{% block title %}Categories{% endblock %}
{% block breadcrumb %}Catalog / Categories{% endblock %}

{% block body %}
{% set route_prefix = categories_route_prefix|default('admin_categories') %}
<div class="page-header d-flex justify-content-between align-items-center">
    <h1>Categories Management</h1>
    <a href="{{ path(route_prefix ~ '_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add Category
    </a>
</div>

{% for flash_message in app.flashes('success') %}
    <div class="alert alert-success" role="alert">{{ flash_message }}</div>
{% endfor %}
{% for flash_message in app.flashes('error') %}
    <div class="alert alert-danger" role="alert">{{ flash_message }}</div>
{% endfor %}

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Slug</th>
                        <th>Sort</th>
                        <th>Products</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for category in categories %}
                        <tr>
                            <td>
                                <div class="fw-medium">{{ category.name }}</div>
                                <small class="text-muted">{{ category.description ?: 'No description' }}</small>
                            </td>
                            <td><code>{{ category.slug }}</code></td>
                            <td>{{ category.sortOrder }}</td>
                            <td>{{ category.products|length }}</td>
                            <td>
                                {% if category.isActive %}
                                    <span class="badge bg-success">Active</span>
                                {% else %}
                                    <span class="badge bg-secondary">Inactive</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="{{ path(route_prefix ~ '_edit', {id: category.id}) }}" class="btn btn-sm btn-outline-primary btn-icon" title="Edit category" aria-label="Edit category">
                                        <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                    </a>
                                    <form action="{{ path(route_prefix ~ '_toggle', {id: category.id}) }}" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-{{ category.isActive ? 'warning' : 'success' }} btn-icon" title="Toggle status" aria-label="Toggle status">
                                            <i class="bi {{ category.isActive ? 'bi-toggle-off' : 'bi-toggle-on' }}" aria-hidden="true"></i>
                                        </button>
                                    </form>
                                    <form action="{{ path(route_prefix ~ '_delete', {id: category.id}) }}" method="post" class="d-inline" onsubmit="return confirm('Delete this category?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger btn-icon" title="Delete category" aria-label="Delete category">
                                            <i class="bi bi-trash" aria-hidden="true"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">No categories found.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
