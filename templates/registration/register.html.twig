{% extends 'customer/base.html.twig' %}

{% block title %}Create Account{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="text-center mb-4">
                <h1 class="h3">Create an Account</h1>
                <p class="text-muted">Join VapeShop to start shopping</p>
            </div>
            
            <div class="card">
                <div class="card-body p-4">
                    <div class="d-grid mb-3">
                        <a href="{{ path('oauth_google_customer_connect') }}" class="btn btn-outline-dark">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48" class="me-2">
                                <path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24c0,11.045,8.955,20,20,20c11.045,0,20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"/>
                                <path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"/>
                                <path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z"/>
                                <path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571c0.001-0.001,0.002-0.001,0.003-0.002l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"/>
                            </svg>
                            Sign up with Google
                        </a>
                    </div>
                    
                    <div class="d-flex align-items-center mb-3">
                        <hr class="flex-grow-1">
                        <span class="px-3 text-muted" style="font-size: 0.875rem;">or register with email</span>
                        <hr class="flex-grow-1">
                    </div>

                    {{ form_start(registrationForm, {attr: {class: 'needs-validation', novalidate: 'novalidate'}}) }}
                    
                    <div class="row mb-3">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label class="form-label">{{ form_label(registrationForm.firstName) }}</label>
                            {{ form_widget(registrationForm.firstName) }}
                            {{ form_errors(registrationForm.firstName) }}
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">{{ form_label(registrationForm.lastName) }}</label>
                            {{ form_widget(registrationForm.lastName) }}
                            {{ form_errors(registrationForm.lastName) }}
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">{{ form_label(registrationForm.email) }}</label>
                        {{ form_widget(registrationForm.email) }}
                        {{ form_errors(registrationForm.email) }}
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">{{ form_label(registrationForm.plainPassword.first) }}</label>
                        {{ form_widget(registrationForm.plainPassword.first) }}
                        {{ form_errors(registrationForm.plainPassword.first) }}
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">{{ form_label(registrationForm.plainPassword.second) }}</label>
                        {{ form_widget(registrationForm.plainPassword.second) }}
                        {{ form_errors(registrationForm.plainPassword.second) }}
                    </div>
                    
                    <div class="mb-3">
                        <div class="form-check">
                            {{ form_widget(registrationForm.agreeAge, {attr: {class: 'form-check-input'}}) }}
                            {{ form_label(registrationForm.agreeAge, null, {label_attr: {class: 'form-check-label', style: 'font-size: 0.875rem;'}}) }}
                        </div>
                        {{ form_errors(registrationForm.agreeAge) }}
                    </div>
                    
                    <div class="mb-4">
                        <div class="form-check">
                            {{ form_widget(registrationForm.agreeTerms, {attr: {class: 'form-check-input'}}) }}
                            {{ form_label(registrationForm.agreeTerms, null, {label_attr: {class: 'form-check-label', style: 'font-size: 0.875rem;'}}) }}
                        </div>
                        {{ form_errors(registrationForm.agreeTerms) }}
                    </div>
                    
                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-primary btn-lg">Create Account</button>
                    </div>
                    
                    {{ form_end(registrationForm) }}
                    
                    <div class="text-center text-muted" style="font-size: 0.875rem;">
                        Already have an account? <a href="{{ path('app_login') }}">Login</a>
                    </div>
                </div>
            </div>
            
            <div class="alert alert-info mt-4" style="font-size: 0.8125rem;">
                <i class="bi bi-info-circle me-2"></i>
                <strong>Age Verification Required:</strong> To purchase vape products, you'll need to verify your age (21+) after registering. This is a one-time process to comply with regulations.
            </div>
        </div>
    </div>
</div>
{% endblock %}
