{% extends 'staff/base.html.twig' %}

{% block title %}Ship Order #{{ order.orderNumber ?? ('ORD-' ~ order.id) }}{% endblock %}
{% block breadcrumb %}Ready to Ship / Ship #{{ order.orderNumber ?? ('ORD-' ~ order.id) }}{% endblock %}

{% block body %}
{% set shipment = order.shipment %}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1>Ship Order #{{ order.orderNumber ?? ('ORD-' ~ order.id) }}</h1>
        <span class="badge bg-primary">Ready to Ship</span>
    </div>
    <div class="d-flex gap-2">
        <a href="{{ path('staff_orders_ready') }}" class="btn btn-outline-secondary">Back to Ready to Ship</a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-truck me-2"></i>Shipping Details</h5>
            </div>
            <div class="card-body">
                <form action="{{ path('staff_orders_ship', {id: order.id}) }}" method="POST">
                    <input type="hidden" name="_token" value="{{ csrf_token('ship-order-' ~ order.id) }}">
                    
                    <div class="mb-3">
                        <label for="courier" class="form-label">Courier <span class="text-danger">*</span></label>
                        <select class="form-select" id="courier" name="courier" required>
                            <option value="">-- Select Courier --</option>
                            {% for key, label in couriers %}
                                <option value="{{ key }}" {% if shipment and shipment.courier == key %}selected{% endif %}>{{ label }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="tracking_number" class="form-label">Tracking Number <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="tracking_number" name="tracking_number" 
                               value="{{ shipment.trackingNumber ?? '' }}" 
                               placeholder="Enter the tracking number from the courier" required>
                        <div class="form-text">Enter the tracking number provided by the courier after pickup.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-send me-1"></i> Mark as Shipped
                        </button>
                        <a href="{{ path('staff_orders_ready') }}" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0">Order Items</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th>SKU</th>
                                <th class="text-center">Qty</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in order.items %}
                                <tr>
                                    <td>{{ item.productName }}</td>
                                    <td><code>{{ item.variantSku ?: 'N/A' }}</code></td>
                                    <td class="text-center"><span class="badge bg-primary">{{ item.quantity }}</span></td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header bg-white">
                <h5 class="mb-0">Ship To</h5>
            </div>
            <div class="card-body">
                {% if order.shippingAddress %}
                    <address class="mb-0">
                        <strong>{{ order.shippingAddress.fullName }}</strong><br>
                        {{ order.shippingAddress.streetAddress }}<br>
                        {% if order.shippingAddress.barangay %}{{ order.shippingAddress.barangay }}<br>{% endif %}
                        {{ order.shippingAddress.city }}, {{ order.shippingAddress.province }} {{ order.shippingAddress.postalCode }}<br>
                        <abbr title="Phone">P:</abbr> {{ order.shippingAddress.phone }}
                    </address>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <span>Region:</span>
                        <strong>{{ order.shippingAddress.regionLabel }}</strong>
                    </div>
                {% else %}
                    <p class="text-muted mb-0">No shipping address available.</p>
                {% endif %}
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-white">
                <h5 class="mb-0">Customer</h5>
            </div>
            <div class="card-body">
                <div class="mb-2">
                    <strong>{{ order.user ? order.user.fullName : 'Unknown Customer' }}</strong>
                </div>
                <div class="mb-2">
                    <small class="text-muted">Email:</small><br>
                    {{ order.user ? order.user.email : 'N/A' }}
                </div>
                <div>
                    <small class="text-muted">Phone:</small><br>
                    {{ order.user and order.user.phone ? order.user.phone : 'N/A' }}
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0">Order Total</h5>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between fw-bold fs-5">
                    <span>Total</span>
                    <span>₱{{ order.total|number_format(2, '.', ',') }}</span>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
