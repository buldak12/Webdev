{% extends 'staff/base.html.twig' %}

{% block title %}Returns & Refunds{% endblock %}
{% block breadcrumb %}Returns & Refunds{% endblock %}

{% block body %}
<div class="page-header d-flex justify-content-between align-items-center">
    <h1>Returns & Refunds</h1>
</div>

<div class="alert alert-warning mb-4">
    This page now uses live refunded order data. Dedicated return-request workflow records are not yet modeled in the database.
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-center py-3 border-warning">
            <div class="h4 mb-0 text-warning">{{ returns_summary.pending_review }}</div>
            <small class="text-muted">Pending Review</small>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center py-3 border-info">
            <div class="h4 mb-0 text-info">{{ returns_summary.in_transit }}</div>
            <small class="text-muted">In Transit (Return)</small>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center py-3 border-success">
            <div class="h4 mb-0 text-success">{{ returns_summary.refunded_count }}</div>
            <small class="text-muted">Refunded Orders</small>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center py-3">
            <div class="h4 mb-0">₱{{ returns_summary.total_refunded|number_format(2, '.', ',') }}</div>
            <small class="text-muted">Total Refunded</small>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Recent Refunded Orders</h5>
        <span class="badge bg-success">{{ returns_summary.refunded_count }} total</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Order</th>
                        <th>Customer</th>
                        <th>Refund Amount</th>
                        <th>Payment Method</th>
                        <th>Updated</th>
                    </tr>
                </thead>
                <tbody>
                    {% for order in refunded_orders %}
                        {% set payment = order.successfulPayment %}
                        <tr>
                            <td><strong>#{{ order.orderNumber ?? ('ORD-' ~ order.id) }}</strong></td>
                            <td>
                                <div>{{ order.user ? order.user.fullName : 'Unknown Customer' }}</div>
                                <small class="text-muted">{{ order.user ? order.user.email : 'N/A' }}</small>
                            </td>
                            <td>₱{{ order.total|number_format(2, '.', ',') }}</td>
                            <td>
                                <span class="badge bg-light text-dark">{{ payment ? payment.gatewayLabel : 'N/A' }}</span>
                            </td>
                            <td>{{ order.updatedAt ? order.updatedAt|date('M j, Y g:i A') : 'N/A' }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">No refunded orders found yet.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
