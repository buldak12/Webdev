{% extends 'customer/base.html.twig' %}

{% block title %}My Orders{% endblock %}

{% block body %}
<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb" style="font-size: 0.8125rem;">
            <li class="breadcrumb-item"><a href="{{ path('account_index') }}">Account</a></li>
            <li class="breadcrumb-item active">Orders</li>
        </ol>
    </nav>
    
    <h1 class="h4 mb-4">My Orders</h1>
    
    {% if orders|length > 0 %}
        <div class="card">
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Order Number</th>
                            <th>Date</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for order in orders %}
                            {% set statusClass = {
                                'pending': 'warning',
                                'awaiting_verification': 'warning',
                                'awaiting_payment': 'secondary',
                                'paid': 'primary',
                                'processing': 'info',
                                'ready_to_ship': 'primary',
                                'shipped': 'dark',
                                'delivered': 'success',
                                'cancelled': 'danger',
                                'refunded': 'secondary'
                            } %}
                            <tr>
                                <td>
                                    <a href="{{ path('account_order_show', {id: order.id}) }}" class="text-decoration-none fw-medium">
                                        #{{ order.orderNumber }}
                                    </a>
                                </td>
                                <td>{{ order.createdAt|date('M j, Y g:i A') }}</td>
                                <td>{{ order.items|length }} item(s)</td>
                                <td>₱{{ order.total|number_format(2) }}</td>
                                <td><span class="badge bg-{{ statusClass[order.status] ?? 'secondary' }}">{{ order.statusLabel }}</span></td>
                                <td>
                                    <a href="{{ path('account_order_show', {id: order.id}) }}" class="btn btn-sm btn-outline-primary">
                                        View Details
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% else %}
        <div class="text-center py-5">
            <i class="bi bi-box text-muted" style="font-size: 4rem;"></i>
            <h5 class="mt-3">No Orders Yet</h5>
            <p class="text-muted">You haven't placed any orders yet.</p>
            <a href="{{ path('shop_index') }}" class="btn btn-primary">Start Shopping</a>
        </div>
    {% endif %}
</div>
{% endblock %}
