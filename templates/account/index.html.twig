{% extends 'customer/base.html.twig' %}

{% block title %}My Account{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-lg-3 mb-4">
            <div class="card">
                <div class="card-body">
                    <div class="text-center mb-3">
                        <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <span style="font-size: 1.5rem;">{{ user.firstName|first }}{{ user.lastName|first }}</span>
                        </div>
                        <h6 class="mt-2 mb-0">{{ user.fullName }}</h6>
                        <small class="text-muted">{{ user.email }}</small>
                    </div>
                    
                    <hr>
                    
                    <nav class="nav flex-column">
                        <a class="nav-link active" href="{{ path('account_index') }}"><i class="bi bi-grid me-2"></i>Dashboard</a>
                        <a class="nav-link" href="{{ path('account_orders') }}"><i class="bi bi-box me-2"></i>My Orders</a>
                        <a class="nav-link" href="{{ path('account_addresses') }}"><i class="bi bi-geo-alt me-2"></i>Addresses</a>
                        <a class="nav-link" href="{{ path('account_profile') }}"><i class="bi bi-person me-2"></i>Profile</a>
                        {% if not user.ageVerified %}
                            <a class="nav-link text-warning" href="{{ path('account_verify_age') }}"><i class="bi bi-shield-exclamation me-2"></i>Verify Age</a>
                        {% endif %}
                        <hr>
                        <a class="nav-link text-danger" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-2"></i>Logout</a>
                    </nav>
                </div>
            </div>
        </div>
        
        <!-- Main Content -->
        <div class="col-lg-9">
            <h1 class="h4 mb-4">Dashboard</h1>
            
            <!-- Stats -->
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body text-center">
                            <i class="bi bi-box text-primary" style="font-size: 1.5rem;"></i>
                            <h3 class="mt-2 mb-0">{{ user.orders|length }}</h3>
                            <small class="text-muted">Total Orders</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body text-center">
                            <i class="bi bi-star text-warning" style="font-size: 1.5rem;"></i>
                            <h3 class="mt-2 mb-0">{{ user.loyaltyPoints }}</h3>
                            <small class="text-muted">Loyalty Points</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body text-center">
                            {% if user.ageVerified %}
                                <i class="bi bi-shield-check text-success" style="font-size: 1.5rem;"></i>
                                <h6 class="mt-2 mb-0 text-success">Verified</h6>
                            {% else %}
                                <i class="bi bi-shield-exclamation text-warning" style="font-size: 1.5rem;"></i>
                                <h6 class="mt-2 mb-0 text-warning">Not Verified</h6>
                            {% endif %}
                            <small class="text-muted">Age Status</small>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Age Verification Alert -->
            {% if not user.ageVerified %}
                <div class="alert alert-warning d-flex align-items-center mb-4">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    <div class="flex-grow-1">
                        <strong>Age Verification Required</strong><br>
                        <small>Verify your age to purchase restricted products.</small>
                    </div>
                    <a href="{{ path('account_verify_age') }}" class="btn btn-sm btn-warning">Verify Now</a>
                </div>
            {% endif %}
            
            <!-- Recent Orders -->
            <div class="card">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Recent Orders</h5>
                    <a href="{{ path('account_orders') }}" class="btn btn-sm btn-outline-primary">View All</a>
                </div>
                <div class="card-body p-0">
                    {% if recent_orders|length > 0 %}
                        <table class="table mb-0">
                            <thead>
                                <tr>
                                    <th>Order</th>
                                    <th>Date</th>
                                    <th>Total</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for order in recent_orders %}
                                    {% set statusClass = {
                                        'pending': 'warning',
                                        'awaiting_payment': 'secondary',
                                        'paid': 'primary',
                                        'processing': 'info',
                                        'shipped': 'dark',
                                        'delivered': 'success',
                                        'cancelled': 'danger',
                                        'refunded': 'secondary'
                                    } %}
                                    <tr>
                                        <td><a href="{{ path('account_order_show', {id: order.id}) }}" class="text-decoration-none">#{{ order.orderNumber }}</a></td>
                                        <td>{{ order.createdAt|date('M j, Y') }}</td>
                                        <td>₱{{ order.total|number_format(2) }}</td>
                                        <td><span class="badge bg-{{ statusClass[order.status] ?? 'secondary' }}">{{ order.statusLabel }}</span></td>
                                        <td><a href="{{ path('account_order_show', {id: order.id}) }}" class="btn btn-sm btn-outline-primary">View</a></td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    {% else %}
                        <div class="text-center py-4">
                            <i class="bi bi-box text-muted" style="font-size: 2rem;"></i>
                            <p class="text-muted mt-2 mb-0">No orders yet</p>
                            <a href="{{ path('shop_index') }}" class="btn btn-primary btn-sm mt-2">Start Shopping</a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
