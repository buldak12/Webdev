{% extends 'customer/base.html.twig' %}

{% block title %}My Addresses{% endblock %}
{% form_theme address_form 'bootstrap_5_layout.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .address-modal {
            border: 1px solid var(--color-border);
            border-radius: 0.875rem;
        }
        .address-modal .modal-header {
            position: sticky;
            top: 0;
            z-index: 2;
            background: #fff;
            border-bottom: 1px solid var(--color-border);
            padding: 0.9rem 1.1rem;
        }
        .address-modal .modal-body {
            padding: 1rem 1.1rem;
        }
        .address-modal .modal-footer {
            position: sticky;
            bottom: 0;
            z-index: 2;
            background: #fff;
            border-top: 1px solid var(--color-border);
            padding: 0.85rem 1.1rem;
            gap: 0.5rem;
        }
        .address-modal .form-label {
            font-size: 0.8125rem;
            font-weight: 600;
            margin-bottom: 0.35rem;
        }
        .address-modal .form-control,
        .address-modal .form-select {
            padding-top: 0.5rem;
            padding-bottom: 0.5rem;
        }
        .address-modal .mb-3 {
            margin-bottom: 0.75rem !important;
        }
        .address-modal [data-address-lookup-results] {
            border-radius: 0.5rem;
        }
        @media (max-width: 575.98px) {
            .address-modal .modal-body {
                max-height: 62vh;
                overflow-y: auto;
            }
            .address-modal .modal-footer .btn {
                flex: 1 1 0;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb" style="font-size: 0.8125rem;">
            <li class="breadcrumb-item"><a href="{{ path('account_index') }}">Account</a></li>
            <li class="breadcrumb-item active">Addresses</li>
        </ol>
    </nav>
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h4 mb-0">My Addresses</h1>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newAddressModal">
            <i class="bi bi-plus me-1"></i>Add Address
        </button>
    </div>
    
    {% if addresses|length > 0 %}
        <div class="row g-3">
            {% for address in addresses %}
                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h6 class="mb-0">{{ address.fullName }}</h6>
                                    {% if address.isDefaultShipping %}
                                        <span class="badge bg-primary-subtle text-primary">Default</span>
                                    {% endif %}
                                </div>
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-link text-muted" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        {% if not address.isDefaultShipping %}
                                            <li>
                                                <form method="post" action="{{ path('account_address_default', {id: address.id}) }}">
                                                    <button type="submit" class="dropdown-item">Set as Default</button>
                                                </form>
                                            </li>
                                        {% endif %}
                                        <li>
                                            <form method="post" action="{{ path('account_address_delete', {id: address.id}) }}" onsubmit="return confirm('Delete this address?');">
                                                <button type="submit" class="dropdown-item text-danger">Delete</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                            <p class="text-muted mb-1" style="font-size: 0.875rem;">{{ address.phone }}</p>
                            <p class="mb-0" style="font-size: 0.875rem;">{{ address.formattedAddress }}</p>
                            {% if address.notes %}
                                <p class="text-muted mt-2 mb-0" style="font-size: 0.8125rem;">
                                    <i class="bi bi-sticky me-1"></i>{{ address.notes }}
                                </p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-5">
            <i class="bi bi-geo-alt text-muted" style="font-size: 4rem;"></i>
            <h5 class="mt-3">No Addresses Saved</h5>
            <p class="text-muted">Add an address to make checkout faster.</p>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newAddressModal">
                <i class="bi bi-plus me-1"></i>Add Address
            </button>
        </div>
    {% endif %}
</div>

<!-- New Address Modal -->
<div class="modal fade" id="newAddressModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-fullscreen-sm-down">
        <div class="modal-content address-modal">
            {{ form_start(address_form, {action: path('account_addresses'), method: 'POST'}) }}
            <div class="modal-header">
                <h5 class="modal-title">Add New Address</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                {{ form_row(address_form.fullName) }}
                {{ form_row(address_form.phone) }}
                {{ form_row(address_form.streetAddress) }}
                {{ form_row(address_form.barangay) }}
                <div class="row g-2">
                    <div class="col-12 col-md-6">{{ form_row(address_form.city) }}</div>
                    <div class="col-12 col-md-6">{{ form_row(address_form.province) }}</div>
                    <div class="col-12 col-md-6">{{ form_row(address_form.region) }}</div>
                    <div class="col-12 col-md-6">{{ form_row(address_form.postalCode) }}</div>
                </div>
                {{ form_row(address_form.notes) }}
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light border w-100 w-sm-auto" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary w-100 w-sm-auto">Save Address</button>
            </div>
            {{ form_end(address_form) }}
        </div>
    </div>
</div>

{% include 'customer/_partials/address_autocomplete_script.html.twig' %}
{% endblock %}
