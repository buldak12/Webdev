{% extends 'customer/base.html.twig' %}

{% block title %}Verification Pending{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="text-center">
                <i class="bi bi-hourglass-split text-warning" style="font-size: 3rem;"></i>
                <h1 class="h3 mt-3">Verification Pending</h1>
                <p class="text-muted">Your age verification documents are being reviewed.</p>
                
                <div class="card mt-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Submitted</span>
                            <strong>{{ verification.createdAt|date('M j, Y g:i A') }}</strong>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Status</span>
                            <span class="badge bg-warning">Pending Review</span>
                        </div>
                    </div>
                </div>
                
                <p class="text-muted mt-4" style="font-size: 0.875rem;">
                    Verification usually takes 1-2 business days. You'll receive an email once your documents have been reviewed.
                </p>
                
                <a href="{{ path('account_index') }}" class="btn btn-outline-primary mt-2">Back to Account</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
