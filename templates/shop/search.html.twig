{% extends 'customer/base.html.twig' %}

{% block title %}Search Results{% if query %} for "{{ query }}"{% endif %}{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="mb-4">
        <h1 class="h4 mb-2">Search Results</h1>
        {% if query %}
            <p class="text-muted">{{ total_products }} result(s) for "<strong>{{ query }}</strong>"</p>
        {% endif %}
    </div>
    
    <!-- Search Form -->
    <div class="card mb-4">
        <div class="card-body">
            <form action="{{ path('shop_search') }}" method="get" class="row g-2">
                <div class="col-md-10">
                    <input type="search" name="q" class="form-control" placeholder="Search products..." value="{{ query }}" autofocus>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search me-1"></i>Search
                    </button>
                </div>
            </form>
        </div>
    </div>
    
    {% if query and query|length >= 2 %}
        {% if products|length > 0 %}
            <div class="row g-3">
                {% for product in products %}
                    <div class="col-md-6 col-lg-3">
                        {% include 'shop/_product_card.html.twig' %}
                    </div>
                {% endfor %}
            </div>
            
            {% if total_pages > 1 %}
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item {{ current_page == 1 ? 'disabled' : '' }}">
                            <a class="page-link" href="{{ path('shop_search', {q: query, page: current_page - 1}) }}">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                        {% for i in 1..total_pages %}
                            <li class="page-item {{ current_page == i ? 'active' : '' }}">
                                <a class="page-link" href="{{ path('shop_search', {q: query, page: i}) }}">{{ i }}</a>
                            </li>
                        {% endfor %}
                        <li class="page-item {{ current_page == total_pages ? 'disabled' : '' }}">
                            <a class="page-link" href="{{ path('shop_search', {q: query, page: current_page + 1}) }}">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            {% endif %}
        {% else %}
            <div class="text-center py-5">
                <i class="bi bi-search text-muted" style="font-size: 3rem;"></i>
                <h5 class="mt-3">No Results Found</h5>
                <p class="text-muted">Try different keywords or browse our categories.</p>
                <a href="{{ path('shop_index') }}" class="btn btn-primary">Browse All Products</a>
            </div>
        {% endif %}
    {% elseif query %}
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Please enter at least 2 characters to search.
        </div>
    {% else %}
        <div class="text-center py-5">
            <i class="bi bi-search text-muted" style="font-size: 3rem;"></i>
            <h5 class="mt-3">Search Our Products</h5>
            <p class="text-muted">Enter a search term above to find products.</p>
        </div>
    {% endif %}
</div>
{% endblock %}
