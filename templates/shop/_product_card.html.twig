<div class="card h-100 product-card">
    <a href="{{ path('shop_product', {slug: product.slug}) }}" class="text-decoration-none">
        <div class="position-relative">
            <img 
                src="{{ asset(product.mainImage ?? 'assets/images/placeholder.png') }}" 
                alt="{{ product.name }}"
                class="card-img-top"
                style="height: 200px; object-fit: cover;"
            >
            {% if product.requiresAgeVerification %}
                <span class="badge badge-age position-absolute top-0 end-0 m-2">21+</span>
            {% endif %}
        </div>
    </a>
    <div class="card-body">
        <p class="text-muted mb-1" style="font-size: 0.75rem;">{{ product.category.name }}</p>
        <h6 class="card-title mb-1">
            <a href="{{ path('shop_product', {slug: product.slug}) }}" class="text-decoration-none text-dark">
                {{ product.name }}
            </a>
        </h6>
        {% if product.brand %}
            <p class="text-muted mb-2" style="font-size: 0.75rem;">{{ product.brand }}</p>
        {% endif %}
        
        <div class="d-flex justify-content-between align-items-center mt-auto">
            <div>
                {% if product.lowestPrice != product.highestPrice %}
                    <span class="fw-bold">₱{{ product.lowestPrice|number_format(2) }}</span>
                    <span class="text-muted">-</span>
                    <span class="fw-bold">₱{{ product.highestPrice|number_format(2) }}</span>
                {% else %}
                    <span class="fw-bold">₱{{ product.basePrice|number_format(2) }}</span>
                {% endif %}
            </div>
            {% if product.availableStock > 0 %}
                <span class="badge bg-success-subtle text-success">In Stock</span>
            {% else %}
                <span class="badge bg-danger-subtle text-danger">Out of Stock</span>
            {% endif %}
        </div>
    </div>
    <div class="card-footer bg-transparent border-0 pt-0">
        <a href="{{ path('shop_product', {slug: product.slug}) }}" class="btn btn-outline-primary btn-sm w-100">
            <i class="bi bi-eye me-1"></i>View Details
        </a>
    </div>
</div>

<style>
.product-card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
}
</style>
