{% extends 'customer/base.html.twig' %}

{% block title %}Premium Vaping Products{% endblock %}

{% block body %}
{# ============================================
   SECTION 1: HERO
   ============================================ #}
<section class="hero-section position-relative overflow-hidden">
    <div class="hero-bg"></div>
    <div class="container position-relative py-5">
        <div class="row align-items-center min-vh-50 py-5">
            <div class="col-lg-6">
                <span class="badge bg-white bg-opacity-20 text-white mb-3 px-3 py-2">
                    <i class="bi bi-stars me-1"></i> Premium Quality Since 2020
                </span>
                <h1 class="display-4 fw-bold text-white mb-3 lh-sm">
                    Elevate Your<br>Vaping Experience
                </h1>
                <p class="lead text-white text-opacity-75 mb-4">
                    Discover curated premium vapes, authentic e-liquids, and accessories. 
                    Quality you can trust, delivered to your door.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="{{ path('shop_index') }}" class="btn btn-light btn-lg px-4">
                        <i class="bi bi-bag me-2"></i>Shop Now
                    </a>
                    <a href="{{ path('page_about') }}" class="btn btn-outline-light btn-lg px-4">
                        Learn More
                    </a>
                </div>
                <div class="d-flex gap-4 mt-4 pt-2">
                    <div class="text-white">
                        <div class="h3 mb-0 fw-bold">500+</div>
                        <small class="text-white-50">Products</small>
                    </div>
                    <div class="text-white">
                        <div class="h3 mb-0 fw-bold">10K+</div>
                        <small class="text-white-50">Customers</small>
                    </div>
                    <div class="text-white">
                        <div class="h3 mb-0 fw-bold">4.9★</div>
                        <small class="text-white-50">Rating</small>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block">
                <div class="hero-visual text-center">
                    <div class="hero-glow"></div>
                    <div class="hero-brand-card">
                        <div class="hero-brand-badge">
                            <img src="{{ asset('uploads/products/logo.jpg') }}" alt="Easy Vape logo" class="hero-brand-logo">
                        </div>
                        <div>
                            <p class="text-white-50 small mb-1 text-uppercase">Curated visual identity</p>
                            <h3 class="h5 text-white mb-0">Easy Vape</h3>
                        </div>
                    </div>
                    <div class="hero-image-grid">
                        {% for image in brand_images|slice(0, 4) %}
                            <div class="hero-image-tile tile-{{ loop.index }}">
                                <img src="{{ asset(image) }}" alt="Easy Vape showcase image {{ loop.index }}">
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{# ============================================
   SECTION 2: TRUST BADGES / FEATURES
   ============================================ #}
<section class="py-4 border-bottom bg-white">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-6 col-md-3">
                <div class="d-flex flex-column align-items-center">
                    <div class="feature-icon mb-2">
                        <i class="bi bi-truck"></i>
                    </div>
                    <strong style="font-size: 0.875rem;">Free Shipping</strong>
                    <small class="text-muted">Orders ₱2,000+</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="d-flex flex-column align-items-center">
                    <div class="feature-icon mb-2">
                        <i class="bi bi-patch-check"></i>
                    </div>
                    <strong style="font-size: 0.875rem;">100% Authentic</strong>
                    <small class="text-muted">Genuine Products</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="d-flex flex-column align-items-center">
                    <div class="feature-icon mb-2">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <strong style="font-size: 0.875rem;">Secure Payment</strong>
                    <small class="text-muted">SSL Encrypted</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="d-flex flex-column align-items-center">
                    <div class="feature-icon mb-2">
                        <i class="bi bi-headset"></i>
                    </div>
                    <strong style="font-size: 0.875rem;">24/7 Support</strong>
                    <small class="text-muted">Always Here</small>
                </div>
            </div>
        </div>
    </div>
</section>

{# ============================================
   SECTION 3: CATEGORIES
   ============================================ #}
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="h3 fw-bold">4 Vape Product Categories</h2>
            <p class="text-muted">Choose the device style that matches your vaping preference</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="category-card d-block text-decoration-none h-100">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center py-4 d-flex flex-column">
                            <div class="category-icon mx-auto mb-3">
                                <i class="bi bi-lightning-charge-fill"></i>
                            </div>
                            <h5 class="card-title mb-2 text-dark">Disposables</h5>
                            <p class="text-muted small mb-0">
                                Single-use devices that come pre-filled and pre-charged. Once the e-liquid or battery is depleted, the entire unit is replaced.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="category-card d-block text-decoration-none h-100">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center py-4 d-flex flex-column">
                            <div class="category-icon mx-auto mb-3">
                                <i class="bi bi-grid-3x3-gap-fill"></i>
                            </div>
                            <h5 class="card-title mb-2 text-dark">Pod Systems</h5>
                            <p class="text-muted small mb-0">
                                Compact, low-power devices that use plastic pods rather than glass tanks. Available in closed (pre-filled) or open (refillable) versions and designed for portability.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="category-card d-block text-decoration-none h-100">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center py-4 d-flex flex-column">
                            <div class="category-icon mx-auto mb-3">
                                <i class="bi bi-pen-fill"></i>
                            </div>
                            <h5 class="card-title mb-2 text-dark">Vape Pens</h5>
                            <p class="text-muted small mb-0">
                                Slim, cylindrical devices that bridge the gap between pods and mods. They usually include a refillable tank and single-button operation for simple performance.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="category-card d-block text-decoration-none h-100">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center py-4 d-flex flex-column">
                            <div class="category-icon mx-auto mb-3">
                                <i class="bi bi-cpu-fill"></i>
                            </div>
                            <h5 class="card-title mb-2 text-dark">Mods</h5>
                            <p class="text-muted small mb-0">
                                Powerful, high-wattage devices (Box Mods or Pod Mods) for advanced customization. They often feature replaceable batteries and deeper control options.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="text-center mt-4">
            <a href="{{ path('shop_index') }}" class="btn btn-outline-dark">
                View All Products <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>
    </div>
</section>

{# ============================================
   SECTION 4: FEATURED PRODUCTS
   ============================================ #}
<section class="py-5 bg-light">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="h3 fw-bold mb-1">Featured Products</h2>
                <p class="text-muted mb-0">Hand-picked favorites from our collection</p>
            </div>
            <a href="{{ path('shop_index') }}" class="btn btn-dark d-none d-md-inline-flex">
                View All <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>
        <div class="row g-4">
            {% for product in featured_products|slice(0, 4) %}
                <div class="col-md-6 col-lg-3">
                    {% include 'shop/_product_card.html.twig' %}
                </div>
            {% else %}
                <div class="col-12 text-center py-5">
                    <i class="bi bi-box text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3">Products coming soon!</p>
                </div>
            {% endfor %}
        </div>
        <div class="text-center mt-4 d-md-none">
            <a href="{{ path('shop_index') }}" class="btn btn-dark">View All Products</a>
        </div>
    </div>
</section>

{# ============================================
   SECTION 5: MOBILE APP SHOWCASE (DIVINO)
   ============================================ #}
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge bg-primary bg-opacity-10 text-primary mb-3 px-3 py-2">
                <i class="bi bi-phone me-1"></i> Download Our App
            </span>
            <h2 class="h3 fw-bold mb-3">Shop Anytime, Anywhere</h2>
            <p class="text-muted">The Divino app brings the Easy Vape experience to your pocket</p>
        </div>
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="app-showcase">
                    <div class="app-phone-mockup">
                        <div class="phone-frame">
                            <div class="phone-content">
                                <div class="app-screen-demo">
                                    <div class="app-header">
                                        <h5 class="text-white mb-0">Divino</h5>
                                        <small class="text-white-50">Premium Vape Shop</small>
                                    </div>
                                    <div class="app-menu-items">
                                        <div class="menu-item active">
                                            <i class="bi bi-house"></i><span>Shop</span>
                                        </div>
                                        <div class="menu-item">
                                            <i class="bi bi-bag"></i><span>Orders</span>
                                        </div>
                                        <div class="menu-item">
                                            <i class="bi bi-bell"></i><span>Notify</span>
                                        </div>
                                        <div class="menu-item">
                                            <i class="bi bi-person"></i><span>Profile</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <h3 class="fw-bold mb-4">Why Use Divino?</h3>
                <div class="app-feature mb-4">
                    <div class="feature-icon mb-3">
                        <i class="bi bi-lightning-charge-fill"></i>
                    </div>
                    <h5 class="fw-semibold">Lightning Fast Checkout</h5>
                    <p class="text-muted mb-0">Complete your purchase in seconds with our streamlined mobile checkout process.</p>
                </div>
                <div class="app-feature mb-4">
                    <div class="feature-icon mb-3">
                        <i class="bi bi-bell-fill"></i>
                    </div>
                    <h5 class="fw-semibold">Real-Time Notifications</h5>
                    <p class="text-muted mb-0">Get instant updates on order status, new products, and exclusive app-only deals.</p>
                </div>
                <div class="app-feature mb-4">
                    <div class="feature-icon mb-3">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h5 class="fw-semibold">Secure & Reliable</h5>
                    <p class="text-muted mb-0">Your data is protected with military-grade encryption and built on React Native.</p>
                </div>
                <div class="app-feature">
                    <div class="feature-icon mb-3">
                        <i class="bi bi-bookmark-fill"></i>
                    </div>
                    <h5 class="fw-semibold">Wishlist & Favorites</h5>
                    <p class="text-muted mb-0">Save your favorite products and never miss a restock or price drop alert.</p>
                </div>
                <div class="d-flex gap-3 mt-5">
                    <a href="#" class="btn btn-dark d-flex align-items-center gap-2">
                        <i class="bi bi-apple"></i>
                        <div class="text-start">
                            <div style="font-size: 0.75rem;">Download on</div>
                            <div class="fw-bold">App Store</div>
                        </div>
                    </a>
                    <a href="#" class="btn btn-dark d-flex align-items-center gap-2">
                        <i class="bi bi-google-play"></i>
                        <div class="text-start">
                            <div style="font-size: 0.75rem;">Get it on</div>
                            <div class="fw-bold">Google Play</div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

{# ============================================
   SECTION 6: AGE VERIFICATION / COMPLIANCE
   ============================================ #}
<section class="py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="age-notice-visual">
                    <div class="age-badge">
                        <span class="age-number">21+</span>
                        <span class="age-text">Only</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <h2 class="h3 fw-bold mb-3">Age Verification Required</h2>
                <p class="text-muted mb-4">
                    In compliance with Philippine regulations, all vape product purchases require age verification.
                    You must be 21 years or older to purchase from Easy Vape Philippines.
                </p>
                <ul class="list-unstyled mb-4">
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Quick one-time verification</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Secure document handling</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Usually approved within 24 hours</li>
                </ul>
                {% if not app.user %}
                    <a href="{{ path('app_register') }}" class="btn btn-primary">
                        <i class="bi bi-person-plus me-2"></i>Create Account
                    </a>
                {% elseif not app.user.ageVerified %}
                    <a href="{{ path('account_verify_age') }}" class="btn btn-warning">
                        <i class="bi bi-shield-check me-2"></i>Verify Your Age
                    </a>
                {% else %}
                    <div class="d-inline-flex align-items-center bg-success bg-opacity-10 text-success px-3 py-2 rounded">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        <span>You're verified!</span>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>

{# ============================================
   SECTION 7: NEWSLETTER / CTA
   ============================================ #}
<section class="py-5 bg-dark text-white">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <h2 class="h3 fw-bold mb-3">Stay Updated</h2>
                <p class="text-white-50 mb-4">
                    Get notified about new products, exclusive deals, and vaping tips. No spam, ever.
                </p>
                <form class="row g-2 justify-content-center" onsubmit="event.preventDefault(); alert('Thank you for subscribing!');">
                    <div class="col-sm-8 col-md-6">
                        <input type="email" class="form-control form-control-lg" placeholder="Enter your email" required>
                    </div>
                    <div class="col-sm-4 col-md-auto">
                        <button type="submit" class="btn btn-primary btn-lg w-100">Subscribe</button>
                    </div>
                </form>
                <small class="text-white-50 mt-3 d-block">
                    <i class="bi bi-shield-lock me-1"></i>We respect your privacy
                </small>
            </div>
        </div>
    </div>
</section>

{# ============================================
   SECTION 8: WHY CHOOSE US
   ============================================ #}
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="h3 fw-bold">Why Choose Easy Vape?</h2>
            <p class="text-muted">The trusted choice for vapers across the Philippines</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="text-center">
                    <div class="why-icon mx-auto mb-3">
                        <i class="bi bi-award"></i>
                    </div>
                    <h5 class="fw-semibold">Premium Quality</h5>
                    <p class="text-muted small">Only authentic, tested products from trusted manufacturers make it to our shelves.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="text-center">
                    <div class="why-icon mx-auto mb-3">
                        <i class="bi bi-lightning-charge"></i>
                    </div>
                    <h5 class="fw-semibold">Fast Delivery</h5>
                    <p class="text-muted small">Same-day delivery in Metro Manila. Nationwide shipping within 3-5 business days.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="text-center">
                    <div class="why-icon mx-auto mb-3">
                        <i class="bi bi-heart"></i>
                    </div>
                    <h5 class="fw-semibold">Customer First</h5>
                    <p class="text-muted small">Dedicated support team ready to help. Your satisfaction is our priority.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
/* Hero Section */
.hero-section {
    background: linear-gradient(135deg, #18181b 0%, #27272a 50%, #3f3f46 100%);
    min-height: 70vh;
}
.hero-bg {
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}
.hero-glow {
    position: absolute;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.2) 0%, transparent 70%);
    border-radius: 50%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
}
.hero-visual {
    position: relative;
    min-height: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
}
.hero-brand-card {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 1rem 1.25rem;
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.18);
    width: min(100%, 360px);
}
.hero-brand-badge {
    width: 64px;
    height: 64px;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
}
.hero-brand-logo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0.75rem;
}
.hero-image-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    width: 100%;
    max-width: 420px;
    padding-top: 120px;
}
.hero-image-tile {
    overflow: hidden;
    border-radius: 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.18);
    background: rgba(255, 255, 255, 0.08);
    aspect-ratio: 1 / 1;
}
.hero-image-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}
.min-vh-50 { min-height: 50vh; }

/* Feature Icons */
.feature-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: #f4f4f5;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #18181b;
    font-size: 1.1rem;
}


/* Category Cards */
.category-icon {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: linear-gradient(135deg, #f4f4f5 0%, #e4e4e7 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: #18181b;
    transition: all 0.3s ease;
}
.category-card:hover .category-icon {
    background: linear-gradient(135deg, #18181b 0%, #27272a 100%);
    color: #fff;
    transform: scale(1.05);
}
.category-card .card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.category-card:hover .card {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.1) !important;
}

/* Age Notice */
.age-notice-visual {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 200px;
}
.age-badge {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 40px rgba(245, 158, 11, 0.3);
}
.age-number {
    font-size: 3rem;
    font-weight: 800;
    color: #fff;
    line-height: 1;
}
.age-text {
    font-size: 1rem;
    font-weight: 600;
    color: rgba(255,255,255,0.9);
    text-transform: uppercase;
    letter-spacing: 0.1em;
}

/* Why Choose Us */
.why-icon {
    width: 72px;
    height: 72px;
    border-radius: 20px;
    background: #f4f4f5;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    color: #18181b;
}

/* Mobile App Section */
.app-showcase {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    min-height: 500px;
}

.phone-frame {
    width: 280px;
    height: 560px;
    background: #000;
    border-radius: 40px;
    padding: 12px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    position: relative;
    overflow: hidden;
    border: 2px solid #333;
}

.phone-frame::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 150px;
    height: 25px;
    background: #000;
    border-radius: 0 0 25px 25px;
    z-index: 10;
}

.phone-content {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #18181b 0%, #27272a 100%);
    border-radius: 32px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
}

.app-screen-demo {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 30px 15px 15px 15px;
    color: white;
}

.app-header {
    text-align: center;
