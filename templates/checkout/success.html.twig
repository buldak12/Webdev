{% extends 'customer/base.html.twig' %}

{% block title %}Order Confirmed{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="text-center mb-4">
                <div class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                    <i class="bi bi-check-lg" style="font-size: 2.5rem;"></i>
                </div>
                <h1 class="h3 mt-4 mb-2">Thank You for Your Order!</h1>
                <p class="text-muted">Your order has been placed successfully.</p>
            </div>
            
            <div class="card mb-4">
                <div class="card-header bg-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Order #{{ order.orderNumber }}</h5>
                        <span class="badge bg-{{ order.status == 'paid' ? 'success' : (order.status == 'awaiting_payment' ? 'warning' : 'secondary') }}">
                            {{ order.statusLabel }}
                        </span>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h6 class="text-muted mb-2">Shipping Address</h6>
                            <p class="mb-0">
                                <strong>{{ order.shippingAddress.fullName }}</strong><br>
                                {{ order.shippingAddress.phone }}<br>
                                {{ order.shippingAddress.formattedAddress }}
                            </p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted mb-2">Payment Method</h6>
                            {% set payment = order.payments|first %}
                            {% if payment %}
                                <p class="mb-0">{{ payment.gatewayLabel }}</p>
                            {% endif %}
                        </div>
                    </div>
                    
                    <h6 class="text-muted mb-3">Order Items</h6>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th class="text-end">Qty</th>
                                <th class="text-end">Price</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in order.items %}
                                <tr>
                                    <td>
                                        <strong>{{ item.productName }}</strong>
                                        {% if item.variantName %}<br><small class="text-muted">{{ item.variantName }}</small>{% endif %}
                                    </td>
                                    <td class="text-end">{{ item.quantity }}</td>
                                    <td class="text-end">₱{{ item.subtotal|number_format(2) }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="2" class="text-end">Subtotal</td>
                                <td class="text-end">₱{{ order.subtotal|number_format(2) }}</td>
                            </tr>
                            {% if order.discount > 0 %}
                                <tr class="text-success">
                                    <td colspan="2" class="text-end">Discount</td>
                                    <td class="text-end">-₱{{ order.discount|number_format(2) }}</td>
                                </tr>
                            {% endif %}
                            <tr>
                                <td colspan="2" class="text-end">Shipping</td>
                                <td class="text-end">
                                    {% if order.shippingCost == '0.00' %}
                                        <span class="text-success">FREE</span>
                                    {% else %}
                                        ₱{{ order.shippingCost|number_format(2) }}
                                    {% endif %}
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2" class="text-end">VAT (12%)</td>
                                <td class="text-end">₱{{ order.tax|number_format(2) }}</td>
                            </tr>
                            <tr>
                                <td colspan="2" class="text-end"><strong>Total</strong></td>
                                <td class="text-end"><strong class="h5 mb-0">₱{{ order.total|number_format(2) }}</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            
            {% if order.loyaltyPointsEarned > 0 %}
                <div class="alert alert-success">
                    <i class="bi bi-star-fill me-2"></i>
                    You earned <strong>{{ order.loyaltyPointsEarned }} loyalty points</strong> with this order!
                </div>
            {% endif %}
            
            <div class="text-center">
                <a href="{{ path('account_orders') }}" class="btn btn-outline-primary me-2">
                    <i class="bi bi-box me-1"></i>View My Orders
                </a>
                <a href="{{ path('shop_index') }}" class="btn btn-primary">
                    <i class="bi bi-arrow-left me-1"></i>Continue Shopping
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
