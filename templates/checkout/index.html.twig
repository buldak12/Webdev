{% extends 'customer/base.html.twig' %}

{% block title %}Checkout{% endblock %}
{% form_theme address_form 'bootstrap_5_layout.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .address-modal {
            border: 1px solid var(--color-border);
            border-radius: 0.875rem;
        }
        .address-modal .modal-header {
            position: sticky;
            top: 0;
            z-index: 2;
            background: #fff;
            border-bottom: 1px solid var(--color-border);
            padding: 0.9rem 1.1rem;
        }
        .address-modal .modal-body {
            padding: 1rem 1.1rem;
        }
        .address-modal .modal-footer {
            position: sticky;
            bottom: 0;
            z-index: 2;
            background: #fff;
            border-top: 1px solid var(--color-border);
            padding: 0.85rem 1.1rem;
            gap: 0.5rem;
        }
        .address-modal .form-label {
            font-size: 0.8125rem;
            font-weight: 600;
            margin-bottom: 0.35rem;
        }
        .address-modal .form-control,
        .address-modal .form-select {
            padding-top: 0.5rem;
            padding-bottom: 0.5rem;
        }
        .address-modal .mb-3 {
            margin-bottom: 0.75rem !important;
        }
        .address-modal [data-address-lookup-results] {
            border-radius: 0.5rem;
        }
        @media (max-width: 575.98px) {
            .address-modal .modal-body {
                max-height: 62vh;
                overflow-y: auto;
            }
            .address-modal .modal-footer .btn {
                flex: 1 1 0;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="container py-4">
    <h1 class="h4 mb-4">Checkout</h1>
    
    <form method="post" action="{{ path('checkout_place_order') }}" id="checkoutForm">
        <div class="row">
            <!-- Left Column -->
            <div class="col-lg-8">
                <!-- Shipping Address -->
                <div class="card mb-4">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Shipping Address</h5>
                        <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#newAddressModal">
                            <i class="bi bi-plus me-1"></i>Add New
                        </button>
                    </div>
                    <div class="card-body">
                        {% if addresses|length > 0 %}
                            <div class="row g-3">
                                {% for address in addresses %}
                                    <div class="col-md-6">
                                        <div class="card h-100 {{ selected_address and selected_address.id == address.id ? 'border-primary' : '' }}">
                                            <div class="card-body">
                                                <div class="form-check">
                                                    <input 
                                                        class="form-check-input address-radio" 
                                                        type="radio" 
                                                        name="address_id" 
                                                        value="{{ address.id }}"
                                                        id="address{{ address.id }}"
                                                        {{ selected_address and selected_address.id == address.id ? 'checked' : '' }}
                                                        required
                                                    >
                                                    <label class="form-check-label w-100" for="address{{ address.id }}">
                                                        <strong>{{ address.fullName }}</strong>
                                                        {% if address.isDefaultShipping %}
                                                            <span class="badge bg-primary-subtle text-primary ms-1">Default</span>
                                                        {% endif %}
                                                        <p class="mb-1 text-muted" style="font-size: 0.8125rem;">
                                                            {{ address.phone }}
                                                        </p>
                                                        <p class="mb-0 text-muted" style="font-size: 0.8125rem;">
                                                            {{ address.formattedAddress }}
                                                        </p>
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% else %}
                            <div class="text-center py-4">
                                <i class="bi bi-geo-alt text-muted" style="font-size: 2rem;"></i>
                                <p class="text-muted mt-2 mb-3">No saved addresses</p>
                                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newAddressModal">
                                    <i class="bi bi-plus me-1"></i>Add Address
                                </button>
                            </div>
                        {% endif %}
                    </div>
                </div>
                
                <!-- Shipping Method -->
                {% if selected_address %}
                    <div class="card mb-4">
                        <div class="card-header bg-white">
                            <h5 class="mb-0">Shipping Method</h5>
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>Standard Delivery</strong>
                                    <p class="text-muted mb-0" style="font-size: 0.8125rem;">
                                        {{ selected_address.regionLabel }} - 
                                        Est. {{ delivery_estimate.min_date|date('M j') }} - {{ delivery_estimate.max_date|date('M j, Y') }}
                                    </p>
                                </div>
                                <strong>
                                    {% if shipping_cost == '0.00' or shipping_cost == 0 %}
                                        <span class="text-success">FREE</span>
                                    {% else %}
                                        ₱{{ shipping_cost|number_format(2) }}
                                    {% endif %}
                                </strong>
                            </div>
                        </div>
                    </div>
                {% endif %}
                
                <!-- Payment Method -->
                <div class="card mb-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">Payment Method</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            {% for gateway in payment_gateways %}
                                <div class="col-md-6">
                                    <div class="form-check card h-100">
                                        <div class="card-body">
                                            <input 
                                                class="form-check-input" 
                                                type="radio" 
                                                name="payment_gateway" 
                                                value="{{ gateway.code }}"
                                                id="payment_{{ gateway.code }}"
                                                required
                                            >
                                            <label class="form-check-label w-100" for="payment_{{ gateway.code }}">
                                                <strong>{{ gateway.name }}</strong>
                                                <p class="text-muted mb-0" style="font-size: 0.8125rem;">{{ gateway.description }}</p>
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Order Summary -->
            <div class="col-lg-4">
                <div class="card sticky-top" style="top: 100px;">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">Order Summary</h5>
                    </div>
                    <div class="card-body">
                        <!-- Items -->
                        <div class="mb-3" style="max-height: 200px; overflow-y: auto;">
                            {% for item in cart.items %}
                                <div class="d-flex gap-2 mb-2">
                                    <img 
                                        src="{{ asset(item.variant.product.mainImage ?? 'assets/images/placeholder.png') }}" 
                                        width="40" height="40" 
                                        class="rounded"
                                        style="object-fit: cover;"
                                    >
                                    <div class="flex-grow-1">
                                        <div style="font-size: 0.8125rem;">{{ item.variant.product.name }}</div>
                                        <small class="text-muted">{{ item.quantity }} × ₱{{ item.unitPrice|number_format(2) }}</small>
                                    </div>
                                    <strong style="font-size: 0.8125rem;">₱{{ item.subtotal|number_format(2) }}</strong>
                                </div>
                            {% endfor %}
                        </div>
                        
                        <hr>
                        
                        <!-- Totals -->
                        <div class="d-flex justify-content-between mb-2" style="font-size: 0.875rem;">
                            <span>Subtotal</span>
                            <span>₱{{ summary.subtotal|number_format(2) }}</span>
                        </div>
                        {% if summary.discount > 0 %}
                            <div class="d-flex justify-content-between mb-2 text-success" style="font-size: 0.875rem;">
                                <span>Discount</span>
                                <span>-₱{{ summary.discount|number_format(2) }}</span>
                            </div>
                        {% endif %}
                        <div class="d-flex justify-content-between mb-2" style="font-size: 0.875rem;">
                            <span>Shipping</span>
                            <span id="shippingCost">
                                {% if shipping_cost == '0.00' or shipping_cost == 0 %}
                                    <span class="text-success">FREE</span>
                                {% elseif selected_address %}
                                    ₱{{ shipping_cost|number_format(2) }}
                                {% else %}
                                    --
                                {% endif %}
                            </span>
                        </div>
                        <div class="d-flex justify-content-between mb-2" style="font-size: 0.875rem;">
                            <span>VAT (12%)</span>
                            <span>₱{{ summary.tax|number_format(2) }}</span>
                        </div>
                        
                        <hr>
                        
                        <div class="d-flex justify-content-between mb-3">
                            <strong>Total</strong>
                            <strong class="h5 mb-0">
                                {% set total_with_shipping = summary.total|number_format(2, '.', '')|number_format(2, '.', '')|replace({',': ''})|number_format(2) %}
                                ₱{{ (summary.total + shipping_cost)|number_format(2) }}
                            </strong>
                        </div>
                        
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg" {{ addresses|length == 0 ? 'disabled' : '' }}>
                                <i class="bi bi-lock me-2"></i>Place Order
                            </button>
                        </div>
                        
                        <div class="text-center mt-3" style="font-size: 0.75rem; color: #666;">
                            By placing your order, you agree to our Terms of Service and Privacy Policy
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- New Address Modal -->
<div class="modal fade" id="newAddressModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-fullscreen-sm-down">
        <div class="modal-content address-modal">
            {{ form_start(address_form, {action: path('checkout_index'), method: 'POST'}) }}
            <div class="modal-header">
                <h5 class="modal-title">Add New Address</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                {{ form_row(address_form.fullName) }}
                {{ form_row(address_form.phone) }}
                {{ form_row(address_form.streetAddress) }}
                {{ form_row(address_form.barangay) }}
                <div class="row g-2">
                    <div class="col-12 col-md-6">{{ form_row(address_form.city) }}</div>
                    <div class="col-12 col-md-6">{{ form_row(address_form.province) }}</div>
                    <div class="col-12 col-md-6">{{ form_row(address_form.region) }}</div>
                    <div class="col-12 col-md-6">{{ form_row(address_form.postalCode) }}</div>
                </div>
                {{ form_row(address_form.notes) }}
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light border w-100 w-sm-auto" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary w-100 w-sm-auto">Save Address</button>
            </div>
            {{ form_end(address_form) }}
        </div>
    </div>
</div>

{% include 'customer/_partials/address_autocomplete_script.html.twig' %}

<script>
document.querySelectorAll('.address-radio').forEach(radio => {
    radio.addEventListener('change', function() {
        // Reload page with selected address to update shipping
        window.location.href = '{{ path("checkout_index") }}?address=' + this.value;
    });
});
</script>
{% endblock %}
