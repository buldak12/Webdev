{% extends 'customer/base.html.twig' %}

{% block title %}Shopping Cart{% endblock %}

{% block body %}
<div class="container py-4">
    <h1 class="h4 mb-4">Shopping Cart</h1>
    
    {% if errors|length > 0 %}
        <div class="alert alert-warning mb-4">
            <strong><i class="bi bi-exclamation-triangle me-2"></i>Some items need attention:</strong>
            <ul class="mb-0 mt-2">
                {% for error in errors %}
                    <li>{{ error.error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}
    
    {% if cart.items|length > 0 %}
        <div class="row">
            <!-- Cart Items -->
            <div class="col-lg-8 mb-4">
                <div class="card">
                    <div class="card-body p-0">
                        <table class="table table-borderless mb-0">
                            <thead class="border-bottom">
                                <tr>
                                    <th class="ps-3">Product</th>
                                    <th style="width: 100px;">Price</th>
                                    <th style="width: 140px;">Quantity</th>
                                    <th style="width: 100px;">Subtotal</th>
                                    <th style="width: 50px;"></th>
                                </tr>
                            </thead>
                            <tbody id="cartItems">
                                {% for item in cart.items %}
                                    <tr class="cart-item" data-item-id="{{ item.id }}">
                                        <td class="ps-3">
                                            <div class="d-flex align-items-center">
                                                <img 
                                                    src="{{ asset(item.variant.product.mainImage ?? 'assets/images/placeholder.png') }}" 
                                                    alt="{{ item.variant.displayName }}"
                                                    class="rounded me-3"
                                                    style="width: 64px; height: 64px; object-fit: cover;"
                                                >
                                                <div>
                                                    <h6 class="mb-0" style="font-size: 0.9rem;">
                                                        <a href="{{ path('shop_product', {slug: item.variant.product.slug}) }}" class="text-decoration-none text-dark">
                                                            {{ item.variant.product.name }}
                                                        </a>
                                                    </h6>
                                                    <small class="text-muted">{{ item.variant.variantAttributes ?: 'Default' }}</small>
                                                    {% if item.variant.product.requiresAgeVerification %}
                                                        <span class="badge badge-age ms-1">21+</span>
                                                    {% endif %}
                                                </div>
                                            </div>
                                        </td>
                                        <td class="align-middle">₱{{ item.unitPrice|number_format(2) }}</td>
                                        <td class="align-middle">
                                            <div class="input-group input-group-sm">
                                                <button type="button" class="btn btn-outline-secondary btn-qty" data-action="decrease">-</button>
                                                <input type="number" class="form-control text-center qty-input" value="{{ item.quantity }}" min="1" max="{{ item.variant.availableStock }}" style="width: 50px;">
                                                <button type="button" class="btn btn-outline-secondary btn-qty" data-action="increase">+</button>
                                            </div>
                                        </td>
                                        <td class="align-middle fw-medium item-subtotal">₱{{ item.subtotal|number_format(2) }}</td>
                                        <td class="align-middle">
                                            <button type="button" class="btn btn-sm btn-link text-danger btn-remove" title="Remove">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
                
                <div class="d-flex justify-content-between mt-3">
                    <a href="{{ path('shop_index') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Continue Shopping
                    </a>
                </div>
            </div>
            
            <!-- Order Summary -->
            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">Order Summary</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal</span>
                            <span id="summarySubtotal">₱{{ summary.subtotal|number_format(2) }}</span>
                        </div>
                        
                        {% if summary.discount > 0 %}
                            <div class="d-flex justify-content-between mb-2 text-success">
                                <span>Discount</span>
                                <span id="summaryDiscount">-₱{{ summary.discount|number_format(2) }}</span>
                            </div>
                        {% endif %}
                        
                        <div class="d-flex justify-content-between mb-2">
                            <span>VAT (12%)</span>
                            <span id="summaryTax">₱{{ summary.tax|number_format(2) }}</span>
                        </div>
                        
                        <hr>
                        
                        <div class="d-flex justify-content-between mb-3">
                            <strong>Total</strong>
                            <strong class="h5 mb-0" id="summaryTotal">₱{{ summary.total|number_format(2) }}</strong>
                        </div>
                        
                        <!-- Promo Code -->
                        <div class="mb-3">
                            {% if summary.promo_code %}
                                <div class="alert alert-success d-flex justify-content-between align-items-center py-2 mb-0">
                                    <span><i class="bi bi-tag me-1"></i>{{ summary.promo_code }}</span>
                                    <button type="button" class="btn btn-sm btn-link text-danger p-0" id="removePromoBtn">Remove</button>
                                </div>
                            {% else %}
                                <div class="input-group input-group-sm">
                                    <input type="text" class="form-control" id="promoCodeInput" placeholder="Promo code">
                                    <button type="button" class="btn btn-outline-primary" id="applyPromoBtn">Apply</button>
                                </div>
                                <div id="promoMessage" class="mt-1" style="font-size: 0.8125rem;"></div>
                            {% endif %}
                        </div>
                        
                        {% if summary.requires_age_verification %}
                            <div class="alert alert-warning py-2 mb-3" style="font-size: 0.8125rem;">
                                <i class="bi bi-exclamation-triangle me-1"></i>
                                Age verification required at checkout
                            </div>
                        {% endif %}
                        
                        <div class="d-grid">
                            <a href="{{ path('checkout_index') }}" class="btn btn-primary btn-lg">
                                Proceed to Checkout
                            </a>
                        </div>
                        
                        <div class="text-center mt-3" style="font-size: 0.75rem;">
                            <i class="bi bi-shield-check text-success me-1"></i>
                            Secure checkout with SSL encryption
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <div class="text-center py-5">
            <i class="bi bi-bag text-muted" style="font-size: 4rem;"></i>
            <h4 class="mt-3">Your Cart is Empty</h4>
            <p class="text-muted">Looks like you haven't added any products yet.</p>
            <a href="{{ path('shop_index') }}" class="btn btn-primary mt-2">
                <i class="bi bi-arrow-left me-1"></i>Start Shopping
            </a>
        </div>
    {% endif %}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Quantity buttons
    document.querySelectorAll('.btn-qty').forEach(btn => {
        btn.addEventListener('click', function() {
            const row = this.closest('.cart-item');
            const itemId = row.dataset.itemId;
            const input = row.querySelector('.qty-input');
            let qty = parseInt(input.value);
            
            if (this.dataset.action === 'increase') {
                qty = Math.min(qty + 1, parseInt(input.max));
            } else {
                qty = Math.max(qty - 1, 1);
            }
            
            input.value = qty;
            updateCartItem(itemId, qty);
        });
    });
    
    // Quantity input change
    document.querySelectorAll('.qty-input').forEach(input => {
        input.addEventListener('change', function() {
            const row = this.closest('.cart-item');
            const itemId = row.dataset.itemId;
            const qty = Math.max(1, Math.min(parseInt(this.value) || 1, parseInt(this.max)));
            this.value = qty;
            updateCartItem(itemId, qty);
        });
    });
    
    // Remove buttons
    document.querySelectorAll('.btn-remove').forEach(btn => {
        btn.addEventListener('click', function() {
            const row = this.closest('.cart-item');
            const itemId = row.dataset.itemId;
            removeCartItem(itemId, row);
        });
    });
    
    // Apply promo
    document.getElementById('applyPromoBtn')?.addEventListener('click', applyPromo);
    document.getElementById('promoCodeInput')?.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') applyPromo();
    });
    
    // Remove promo
    document.getElementById('removePromoBtn')?.addEventListener('click', removePromo);
});

function updateCartItem(itemId, quantity) {
    fetch('{{ path("cart_update") }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ item_id: itemId, quantity: quantity })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            updateSummary(data.summary);
            updateCartBadge(data.cart_count);
            // Reload to update subtotals
            location.reload();
        } else {
            alert(data.error || 'Error updating cart');
        }
    });
}

function removeCartItem(itemId, row) {
    fetch('{{ path("cart_remove") }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ item_id: itemId })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            row.remove();
            updateSummary(data.summary);
            updateCartBadge(data.cart_count);
            if (data.cart_count === 0) {
                location.reload();
            }
        }
    });
}

function applyPromo() {
    const code = document.getElementById('promoCodeInput').value.trim();
    const msgEl = document.getElementById('promoMessage');
    
    if (!code) {
        msgEl.innerHTML = '<span class="text-danger">Please enter a code</span>';
        return;
    }
    
    fetch('{{ path("cart_apply_promo") }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ code: code })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            msgEl.innerHTML = '<span class="text-danger">' + (data.error || 'Invalid code') + '</span>';
        }
    });
}

function removePromo() {
    fetch('{{ path("cart_remove_promo") }}', {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(() => location.reload());
}

function updateSummary(summary) {
    document.getElementById('summarySubtotal').textContent = '₱' + parseFloat(summary.subtotal).toLocaleString('en-PH', {minimumFractionDigits: 2});
    document.getElementById('summaryTax').textContent = '₱' + parseFloat(summary.tax).toLocaleString('en-PH', {minimumFractionDigits: 2});
    document.getElementById('summaryTotal').textContent = '₱' + parseFloat(summary.total).toLocaleString('en-PH', {minimumFractionDigits: 2});
}

function updateCartBadge(count) {
    let badge = document.getElementById('cartBadge');
    if (count > 0) {
        if (!badge) {
            badge = document.createElement('span');
            badge.id = 'cartBadge';
            badge.className = 'cart-badge';
            document.getElementById('cartDropdownBtn').appendChild(badge);
        }
        badge.textContent = count;
    } else if (badge) {
        badge.remove();
    }
}
</script>
{% endblock %}
